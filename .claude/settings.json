{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/memory/inject-user-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/validate-command.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/financial-data-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/no-secrets-in-output.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/governance/audit-logger.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/trajectories/log-trajectory.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/governance/loop-detection.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/trajectories/finalize-session-trajectory.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/skills/should-reflect.sh"
          }
        ]
      }
    ]
  }
}
