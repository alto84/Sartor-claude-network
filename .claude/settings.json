{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",
      "Agent",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskStop",
      "TaskOutput",
      "TeamCreate",
      "TeamDelete",
      "SendMessage",
      "EnterPlanMode",
      "ExitPlanMode",
      "CronCreate",
      "CronList",
      "CronDelete",
      "RemoteTrigger",
      "NotebookEdit",
      "ToolSearch",
      "Skill",
      "EnterWorktree",
      "ExitWorktree",
      "mcp__claude-in-chrome",
      "mcp__claude-in-chrome__*",
      "mcp__claude_ai_Gmail",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__claude_ai_Hugging_Face",
      "mcp__claude_ai_Hugging_Face__*",
      "mcp__claude_ai_PubMed",
      "mcp__claude_ai_PubMed__*"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/memory/inject-user-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/validate-command.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/financial-data-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/security/no-secrets-in-output.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/governance/audit-logger.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/trajectories/log-trajectory.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/governance/loop-detection.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/trajectories/finalize-session-trajectory.sh"
          },
          {
            "type": "command",
            "command": "bash ./scripts/home-agent/skills/should-reflect.sh"
          }
        ]
      }
    ]
  }
}
