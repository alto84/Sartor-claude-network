/dist/
node_modules/
.next/

# Environment variables
.env
.env.local
.env.*.local
.dev.vars

# Firebase credentials (NEVER commit these!)
config/service-account.json
config/service-account-*.json
**/service-account*.json

# Dashboard config
dashboard/config/service-account.json
dashboard/.env.local

# Workers secrets
workers/*/.dev.vars

# Local data storage
data/
*.db
*.sqlite
config/firebase-credentials.json

# Credentials and secrets
*.pem
*.key
credentials.json
secrets.json
credentials/
.secrets/
*adminsdk*.json
client_secret_*.json
firebase-adminsdk*.json
*.pyc
__pycache__/

# Sartor memory derived artifacts (regenerable from .md files)
sartor/memory/.meta/
sartor/memory/.index/
sartor/memory/indexes/*.json
# Keep indexes/_index.md so the directory is discoverable in Obsidian

# Build artifacts and coverage
coverage/
*.tmp

# Logs
*.log
.swarm/logs/

# Home agent runtime data (generated, not source)
data/home-agent/

# Agent memory (leaked from agents with memory:project before fix)
.claude/agent-memory/
