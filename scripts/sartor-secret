#!/usr/bin/env python3
"""sartor-secret — thin wrapper over the Bitwarden CLI for Sartor secret retrieval.

Reads credentials from a Bitwarden vault via `bw`. Vault must be unlocked: BW_SESSION
must be set in env, OR a session token cached at the Sartor session-cache path. Wrapper
NEVER stores secret values, only the session token (which is itself a vault unlock key).

Usage:
    sartor-secret read <ITEM_NAME> [--field password|username|uri|totp|notes]
    sartor-secret status                  # vault state, no values
    sartor-secret unlock                  # interactive: prompt for master pwd, cache session
    sartor-secret list [--search SUBSTR]  # NAMES ONLY (no values), audit/discovery only

Exit codes:
    0  value retrieved / vault unlocked / list emitted
    2  vault locked  (Alton must run 'sartor-secret unlock' or 'bw unlock' and retry)
    3  item not found OR ambiguous name (more than one result)
    4  prerequisite missing (bw not installed, not logged in)
    5  unexpected error

Reference, do not change cargo-cult: secret values must NEVER be written to a log,
echoed in a non-stdout stream, or persisted anywhere except the vault itself. The `list`
subcommand exists because vault-discovery without leaking values is itself a primitive.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


def session_cache_path() -> Path:
    if sys.platform.startswith("win"):
        base = os.environ.get("LOCALAPPDATA")
        if base:
            return Path(base) / "Sartor" / "bw-session"
    return Path.home() / ".config" / "sartor" / "bw-session"


def load_session() -> str | None:
    env = os.environ.get("BW_SESSION")
    if env:
        return env.strip()
    p = session_cache_path()
    if p.is_file():
        try:
            return p.read_text(encoding="utf-8").strip() or None
        except OSError:
            return None
    return None


def bw_path() -> str | None:
    return shutil.which("bw")


def run_bw(args: list, session: str | None = None) -> subprocess.CompletedProcess:
    bw = bw_path()
    if not bw:
        print("[ERR] bw CLI not found. Install with: npm install -g @bitwarden/cli", file=sys.stderr)
        sys.exit(4)
    env = os.environ.copy()
    if session:
        env["BW_SESSION"] = session
    return subprocess.run(
        [bw, *args],
        env=env,
        capture_output=True,
        text=True,
    )


def bw_status(session: str | None) -> dict:
    cp = run_bw(["status"], session)
    raw = cp.stdout or cp.stderr or "{}"
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return {"status": "error", "raw": raw[:200]}


def cmd_status(args) -> int:
    session = load_session()
    s = bw_status(session)
    state = s.get("status", "unknown")
    user = s.get("userEmail", "?")
    print(f"vault: {state}  user: {user}")
    if state == "unlocked":
        return 0
    if state == "locked":
        print(
            "[BW_LOCKED] Run 'sartor-secret unlock' (or 'bw unlock' and update the cache).",
            file=sys.stderr,
        )
        return 2
    if state == "unauthenticated":
        print(
            "[BW_UNAUTH] Run 'bw login <email>' first; then 'sartor-secret unlock'.",
            file=sys.stderr,
        )
        return 4
    return 5


def cmd_read(args) -> int:
    session = load_session()
    if not session:
        cache = session_cache_path()
        print(
            f"[BW_LOCKED] No BW_SESSION in env or cache ({cache}). "
            f"Run 'sartor-secret unlock' and retry.",
            file=sys.stderr,
        )
        return 2

    s = bw_status(session)
    state = s.get("status")
    if state != "unlocked":
        print(
            f"[BW_LOCKED] Vault state is '{state}'. Run 'sartor-secret unlock' and retry.",
            file=sys.stderr,
        )
        return 2

    cp = run_bw(["get", args.field, args.name], session)
    if cp.returncode != 0:
        msg = (cp.stderr or cp.stdout or "").strip()
        msg_lower = msg.lower()
        # Distinguish: not-found / ambiguous (exit 3) vs auth (exit 4) vs other (exit 5).
        # bw error strings observed in the wild:
        #   "Not found." / "Nothing found"
        #   "More than one result was found"
        #   "You are not logged in" / "Vault is locked"
        if "not found" in msg_lower or "nothing found" in msg_lower:
            print(f"[NOT_FOUND] '{args.name}': {msg}", file=sys.stderr)
            return 3
        if "more than one" in msg_lower:
            print(
                f"[AMBIGUOUS] '{args.name}' matches multiple items: {msg}. "
                f"Use a more specific name.",
                file=sys.stderr,
            )
            return 3
        if "not logged in" in msg_lower:
            print(f"[BW_UNAUTH] {msg}. Run 'bw login <email>'.", file=sys.stderr)
            return 4
        if "vault is locked" in msg_lower or "session" in msg_lower:
            print(
                f"[BW_LOCKED] {msg}. Run 'sartor-secret unlock' and retry.",
                file=sys.stderr,
            )
            return 2
        print(f"[ERR] bw get failed: {msg}", file=sys.stderr)
        return 5
    # Emit value EXACTLY (no trailing newline injected; respect what bw returned, less the
    # one trailing newline bw appends). Caller controls line handling.
    sys.stdout.write(cp.stdout.rstrip("\n"))
    return 0


def cmd_list(args) -> int:
    """Emit vault item names only — never values. Audit/discovery primitive."""
    session = load_session()
    if not session:
        cache = session_cache_path()
        print(
            f"[BW_LOCKED] No BW_SESSION in env or cache ({cache}). "
            f"Run 'sartor-secret unlock' and retry.",
            file=sys.stderr,
        )
        return 2

    s = bw_status(session)
    if s.get("status") != "unlocked":
        print(
            f"[BW_LOCKED] Vault state is '{s.get('status')}'. Run 'sartor-secret unlock' and retry.",
            file=sys.stderr,
        )
        return 2

    bw_args = ["list", "items"]
    if args.search:
        bw_args.extend(["--search", args.search])
    cp = run_bw(bw_args, session)
    if cp.returncode != 0:
        msg = (cp.stderr or cp.stdout or "").strip()
        print(f"[ERR] bw list failed: {msg}", file=sys.stderr)
        return 5
    try:
        items = json.loads(cp.stdout or "[]")
    except json.JSONDecodeError as e:
        print(f"[ERR] bw list returned invalid JSON: {e}", file=sys.stderr)
        return 5
    # Emit names only, one per line. Never login objects, never password fields.
    for it in items:
        name = it.get("name") or "(unnamed)"
        print(name)
    return 0


def cmd_unlock(args) -> int:
    bw = bw_path()
    if not bw:
        print("[ERR] bw CLI not found", file=sys.stderr)
        return 4

    s = bw_status(None)
    if s.get("status") == "unauthenticated":
        print("[BW_UNAUTH] Run 'bw login <email>' first.", file=sys.stderr)
        return 4

    cache = session_cache_path()
    print(f"Unlocking Bitwarden vault. Session will be cached at: {cache}", file=sys.stderr)
    # Capture stdout (the token) but let stderr pass through so the user sees bw's
    # "? Master password:" prompt and can type into stdin normally. stdin is inherited.
    # Earlier version captured stderr=PIPE which hid the prompt — never do that here.
    proc = subprocess.Popen(
        [bw, "unlock", "--raw"],
        stdout=subprocess.PIPE,
        stderr=None,   # inherit — user must see the password prompt
        stdin=None,    # inherit — user types master password here
        text=True,
    )
    out, _ = proc.communicate()
    if proc.returncode != 0:
        print(f"[ERR] unlock failed (exit {proc.returncode})", file=sys.stderr)
        return 5
    token = (out or "").strip()
    if not token:
        print("[ERR] unlock returned empty session token", file=sys.stderr)
        return 5

    cache.parent.mkdir(parents=True, exist_ok=True)
    cache.write_text(token, encoding="utf-8")
    if not sys.platform.startswith("win"):
        os.chmod(cache, 0o600)
    # Tell user how to source it into the current shell. Don't print the token.
    if sys.platform.startswith("win"):
        hint = f"$env:BW_SESSION = (Get-Content '{cache}' -Raw).Trim()"
    else:
        hint = f"export BW_SESSION=\"$(cat {cache})\""
    print(f"[OK] Session cached. Source into your current shell with:\n  {hint}", file=sys.stderr)
    print("[OK] New shells will pick it up automatically if your profile auto-sources the cache.", file=sys.stderr)
    return 0


def main() -> int:
    p = argparse.ArgumentParser(prog="sartor-secret")
    sub = p.add_subparsers(dest="cmd", required=True)

    p_read = sub.add_parser("read", help="retrieve a secret field from the vault")
    p_read.add_argument("name", help="vault item name (e.g., 'BMC rtxserver')")
    p_read.add_argument(
        "--field",
        default="password",
        choices=["password", "username", "uri", "totp", "notes"],
    )
    p_read.set_defaults(func=cmd_read)

    p_status = sub.add_parser("status", help="report vault lock state (no secrets)")
    p_status.set_defaults(func=cmd_status)

    p_unlock = sub.add_parser("unlock", help="interactive unlock + cache session")
    p_unlock.set_defaults(func=cmd_unlock)

    p_list = sub.add_parser("list", help="emit vault item NAMES only (no values)")
    p_list.add_argument("--search", default=None, help="optional substring filter (matched by bw)")
    p_list.set_defaults(func=cmd_list)

    args = p.parse_args()
    return args.func(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
